{
  "compilerOptions": {
    "declaration": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "incremental": true,
    "module": "nodenext",
    "outDir": "./dist",
    "removeComments": true,
    "resolveJsonModule": true,
    "rootDir": "./src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2024",
    "types": ["node"]
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/*spec.ts",
    "test"
  ],
  "watchOptions": {
    "excludeFiles": ["node_modules"]
  }
}
