{
  "name": "nutakortti-backend",
  "version": "3.2.0",
  "description": "Backend for the Nutakortti application",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "test": "cross-env NODE_ENV=test ENABLE_SETUP_ENDPOINTS=yes jest --runInBand",
    "test:e2e": "cross-env NODE_ENV=test ENABLE_SETUP_ENDPOINTS=yes jest --config ./test/jest-e2e.json --runInBand"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.958.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.10",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.10",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.10",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/typeorm": "^11.0.0",
    "@node-saml/node-saml": "^5.1.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.6",
    "date-fns": "^4.1.0",
    "moment": "^2.24.0",
    "nestjs-pino": "^4.5.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "pg": "^8.16.0",
    "rxjs": "^7.5.5",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.10",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/cookie-signature": "^1.1.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "pg-mem": "^3.0.5",
    "prettier": "^3.3.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.2.4",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.8.1",
    "tsconfig-paths": "^4.1.1",
    "typescript": "^6.0.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".spec.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
